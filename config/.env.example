# ═══════════════════════════════════════════════════════════════════════════════
#  SENTINEL SHIELD - Environment Configuration
#  Copy this file to .env and fill in YOUR values
#  DO NOT commit .env with real secrets!
#  Author: Faraone-Dev
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
#                              API SERVER
# ═══════════════════════════════════════════════════════════════════════════════

PORT=8080
NODE_ENV=development

# Database (use strong passwords in production!)
DATABASE_URL=postgresql://sentinel_user:CHANGE_ME@localhost:5432/sentinel
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=sentinel

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# Internal service URLs (Docker networking)
ANALYZER_URL=http://analyzer:5000
DECOMPILER_URL=http://decompiler:3000

# Rate limiting
RATE_LIMIT_RPM=100

# Internal service-to-service key
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY

# CORS
CORS_ORIGINS=http://localhost:80

# ═══════════════════════════════════════════════════════════════════════════════
#                              API KEYS (REQUIRED!)
# ═══════════════════════════════════════════════════════════════════════════════

# Get yours at https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Get yours at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
#                              RPC ENDPOINTS
# ═══════════════════════════════════════════════════════════════════════════════

# Override any RPC (optional - defaults use ALCHEMY_API_KEY)
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# BSC_RPC_URL=https://bsc-dataseed.binance.org
# POLYGON_RPC_URL=https://polygon-rpc.com
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# FANTOM_RPC_URL=https://rpcapi.fantom.network
# ZKSYNC_RPC_URL=https://mainnet.era.zksync.io

# Testnets
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ═══════════════════════════════════════════════════════════════════════════════
#                           SMART CONTRACTS
# ═══════════════════════════════════════════════════════════════════════════════

# Deployer private key (NEVER commit this!)
PRIVATE_KEY=0x...

# Deployed contract addresses (filled after deployment)
SENTINEL_REGISTRY_ETH=
SENTINEL_REGISTRY_POLYGON=
SENTINEL_REGISTRY_ARBITRUM=
SENTINEL_REGISTRY_OPTIMISM=
SENTINEL_REGISTRY_BASE=
SENTINEL_REGISTRY_BSC=

# ═══════════════════════════════════════════════════════════════════════════════
#                              FRONTEND
# ═══════════════════════════════════════════════════════════════════════════════

VITE_API_URL=http://localhost:8080
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ═══════════════════════════════════════════════════════════════════════════════
#                              MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

SENTRY_DSN=
PROMETHEUS_ENABLED=true
WORKERS=2

# ═══════════════════════════════════════════════════════════════════════════════
#                              SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# API key for authenticated endpoints (scan, analyze)
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
